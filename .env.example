# LLM -- Gemini (recommended: fastest, cheapest)
# Get free API key at: aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
LLM_MODEL=gemini-2.5-flash

# OR use OpenAI (comment out Gemini lines above)
# OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# TigerGraph Savanna
# Sign up free at tgcloud.io (~$60 credits, no credit card)
TG_HOST=https://your-instance.i.tgcloud.io
TG_USERNAME=tigergraph
# Use TG_PASSWORD if you set a password, TG_SECRET if using a secret token
TG_PASSWORD=
TG_SECRET=your-secret-here
TG_GRAPH_NAME=LexGraph

# GraphRAG service (from: git clone https://github.com/tigergraph/graphrag)
# Leave as-is if not running the service locally
GRAPHRAG_URL=http://localhost:8000

# Set to "true" to query TigerGraph directly (bypasses REST service)
GRAPHRAG_FALLBACK=true

# Demo mode -- use pre-computed mock results (no LLM/TG needed)
DEMO_MODE=false

# GraphRAG tuning (key levers for token reduction vs accuracy)
# Lower = fewer tokens; do not raise above Basic RAG defaults (5 / 800)
GRAPHRAG_TOP_K=3
GRAPHRAG_HOPS=3
GRAPHRAG_CHUNK_CHARS=300
